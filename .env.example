# ─── DATABASE ──────────────────────────────────────────────────────────────────
# Local PostgreSQL
DATABASE_URL_OFFLINE=postgresql://postgres:yourpassword@localhost:5432/students

# Hosted DB (Neon / Supabase / Railway) — SSL applied automatically
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=verify-full

DB_HOST=localhost
DB_PORT=5432
DB_NAME=students
DB_USER=postgres
DB_PASSWORD=yourpassword

# ─── SERVER ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_RANDOM_HEX

# ─── CLOUDINARY ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── EMAIL (nodemailer) ────────────────────────────────────────────────────────
EMAIL_HOST=live.smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@yourdomain.com
SCHOOL_NAME=SchoolMS

# ─── FRONTEND ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:8081,https://your-frontend.vercel.app

# ─── BACKUPS ───────────────────────────────────────────────────────────────────
# BACKUP_DIR=/absolute/path/to/backups

# ─── REDIS (optional — for caching) ───────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── SMS (optional) ────────────────────────────────────────────────────────────
# SMS_PROVIDER=generic
# SMS_API_URL=https://api.yourprovider.com/send
# SMS_API_KEY=your_api_key
# SMS_SENDER_ID=SchoolMS
# SMS_METHOD=POST
#
# --- OR Twilio ---
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM=+1xxxxxxxxxx

# ─── INBOUND WEBHOOKS ─────────────────────────────────────────────────────────
# Secret that partner systems must sign their POST payloads with
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# INBOUND_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_32_BYTE_HEX

# ─── JAZZCASH (MWALLET / OTP) ─────────────────────────────────────────────────
# Get from JazzCash merchant portal — sandbox values below
JAZZCASH_MERCHANT_ID=your_merchant_id
JAZZCASH_PASSWORD=your_merchant_password
JAZZCASH_INTEGRITY_SALT=your_integrity_salt

# ─── EASYPAISA (Mobile Account) ───────────────────────────────────────────────
# Get from EasyPaisa merchant portal
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_HASH_KEY=your_hash_key

# ─── BACKEND PUBLIC URL (for payment gateway callbacks) ───────────────────────
# Must be publicly reachable by JazzCash / EasyPaisa servers
# In dev use ngrok: https://xxxx.ngrok.io
BACKEND_URL=https://your-backend.example.com
